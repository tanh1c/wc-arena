{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server:dev": "tsx server/index.ts",
    "test:frontend": "node --import tsx --test \"src/**/*.test.ts\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "perf:budget": "npm run build && tsx scripts/verify-performance-budget.ts",
    "perf:lighthouse": "npx lighthouse https://predict-2026.vercel.app --only-categories=performance,accessibility,best-practices,seo --output=json --output-path=./lighthouse-report.json",
    "data:sync:worldcup": "tsx scripts/sync-openfootball-worldcup.ts",
    "data:sync:espn": "tsx scripts/sync-espn-worldcup.ts",
    "data:seed:players": "tsx scripts/seed-wc2026-players.ts",
    "supabase:types": "supabase gen types --linked --lang=typescript > src/types/supabase.ts",
    "supabase:push": "supabase db push --include-seed",
    "supabase:migrations": "supabase migration list --linked"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "country-flag-icons": "^1.6.17",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
